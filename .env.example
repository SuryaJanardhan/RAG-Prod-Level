# Environment: dev or prod
ENVIRONMENT=dev

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

# Vector Database Configuration
# For dev: use Chroma (local)
# For prod: use Qdrant Cloud
VECTOR_DB=chroma  # Options: chroma, qdrant

# Qdrant Cloud Configuration (for prod)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=rag_documents

# Chroma Configuration (for dev)
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Embedding Configuration
EMBEDDING_MODEL=models/embedding-001  # Gemini embedding model
EMBEDDING_DIMENSION=768
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Cache Configuration
# Embedding Cache: SQLite or Redis
EMBEDDING_CACHE_TYPE=sqlite  # Options: sqlite, redis
EMBEDDING_CACHE_SQLITE_PATH=./cache/embeddings.db

# Response Cache: Redis or Postgres
RESPONSE_CACHE_TYPE=redis  # Options: redis, postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=3600  # Cache TTL in seconds

# PostgreSQL Configuration (alternative for response cache)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_cache
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# Retrieval Configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
